{
  "name": "@M324/env",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./server": {
      "development": "./src/server.ts",
      "types": "./dist/server.d.mts",
      "default": "./dist/server.mjs"
    },
    "./web": {
      "development": "./src/web.ts",
      "types": "./dist/web.d.mts",
      "default": "./dist/web.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/server.ts src/web.ts --format esm --dts --out-dir dist",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "dotenv": "^17.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@M324/config": "*",
    "@types/node": "^25.6.0",
    "tsdown": "^0.21.10",
    "typescript": "^6"
  }
}
